{
  "scope": "en-ph",
  "locale": "en-PH",
  "owns": ["question_pool_ph", "dna_copy_ph", "onboarding_copy_ph", "share_copy_ph"],
  "cannot_touch": ["feed_engine", "question_os", "scoring", "admin", "auth"],
  "research_config": {
