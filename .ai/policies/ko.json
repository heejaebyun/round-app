{
  "scope": "ko",
  "locale": "ko-KR",
  "owns": ["question_pool_ko", "dna_copy_ko", "onboarding_copy_ko", "share_copy_ko"],
  "cannot_touch": ["feed_engine", "question_os", "scoring", "admin", "auth"],
  "research_config": {
    "keywords_default": ["직장 갈등", "축의금", "연애 비용", "부모 간섭", "돈 빌려주기", "회식 문화"],
    "batch_size": 4,
    "framing": "더 가까운 쪽은?"
  },
  "quality_rules": {
    "min_split_balance": 35,
    "max_skip_rate_before_review": 40,
    "max_feedback_rate_before_review": 20,
    "categories": ["음식", "커리어", "관계", "소비", "라이프", "여행", "트렌드"],
    "forbidden_topics": ["정치", "젠더전쟁", "혐오", "저격"]
  },
  "auto_update_allowed": {
    "research_config": true,
    "quality_rules": false
  }
}
